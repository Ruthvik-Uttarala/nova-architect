AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.amazon.nova-2-lite-v1:0
NOVA_CONNECT_TIMEOUT=30
NOVA_READ_TIMEOUT=300
NOVA_MAX_TOKENS=1400
NOVA_TEMPERATURE=0.1
NOVA_TOP_P=0.9
ENABLE_LIVE_BEDROCK=1
ENABLE_NOVA_ACT=0
NOVA_ACT_HEADLESS=1
ENABLE_NOVA_SONIC=0
NOVA_SONIC_MODEL_ID=us.amazon.nova-sonic-v1:0
NOVA_SONIC_REGION=us-east-1
NOVA_SONIC_MAX_TOKENS=200
NOVA_SONIC_TEMPERATURE=0.2
NOVA_SONIC_TOP_P=0.9
NOVA_ARTIFACTS_DIR=backend/artifacts
ENABLE_REAL_AWS_MODE=0
DISCOVERY_CACHE_TTL_SECONDS=120
ENABLE_REAL_AWS_CONSOLE=0
REAL_AWS_CONSOLE_ALLOWLIST=console.aws.amazon.com,us-east-1.console.aws.amazon.com

